/js/*
  Cache-Control: no-cache, must-revalidate

/css/*
  Cache-Control: no-cache, must-revalidate

/index.html
  Cache-Control: no-cache, must-revalidate

/manifest.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: no-cache, must-revalidate

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.jpeg
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.mp4
  Cache-Control: public, max-age=31536000, immutable

/data/*.json
  Cache-Control: public, max-age=300, must-revalidate

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), camera=(), microphone=(), interest-cohort=()
  Strict-Transport-Security: max-age=15768000; includeSubDomains
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; media-src 'self' blob:; connect-src 'self' https://chatbot-mairie-mezieres.onrender.com https://api-adresse.data.gouv.fr https://apicarto.ign.fr https://data.geopf.fr https://cadastre.data.gouv.fr https://api.open-meteo.com https://raw.githubusercontent.com https://res.cloudinary.com https://data.education.gouv.fr; worker-src 'self'; frame-src https://www.google.com https://www.facebook.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'
